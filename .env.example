# Copy to .env and fill in values. .env is gitignored.
# These are used by deploy.sh if you prefer env vars over terraform.tfvars.

# DigitalOcean personal access token
DO_TOKEN=dop_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Path to your SSH public key (used by Terraform to upload to the droplet)
SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub
