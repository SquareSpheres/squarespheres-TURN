server {
    listen 80;
    server_name {{ turn_domain }};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name {{ turn_domain }};

    ssl_certificate     /etc/letsencrypt/live/{{ turn_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ turn_domain }}/privkey.pem;

    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    root  /var/www/html;
    index index.html;
}
