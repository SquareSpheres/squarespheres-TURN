# /etc/turnserver.conf — managed by Ansible, do not edit manually.

listening-port={{ turn_listening_port }}
tls-listening-port={{ turn_tls_listening_port }}

realm={{ turn_realm }}

# HMAC-SHA1 REST API credentials (no persistent users needed)
use-auth-secret
static-auth-secret={{ turn_static_secret }}

relay-ip={{ ansible_default_ipv4.address }}
external-ip={{ ansible_default_ipv4.address }}

min-port={{ turn_min_port }}
max-port={{ turn_max_port }}

# TLS certificates — populated by the tls role after certbot runs
{% if turn_cert_path is defined and turn_pkey_path is defined %}
cert={{ turn_cert_path }}
pkey={{ turn_pkey_path }}
{% endif %}

# Block relay to RFC 1918 private addresses
no-multicast-peers
denied-peer-ip=0.0.0.0-0.255.255.255
denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=100.64.0.0-100.127.255.255
denied-peer-ip=127.0.0.0-127.255.255.255
denied-peer-ip=169.254.0.0-169.254.255.255
denied-peer-ip=172.16.0.0-172.31.255.255
denied-peer-ip=192.0.0.0-192.0.0.255
denied-peer-ip=192.168.0.0-192.168.255.255
denied-peer-ip=198.18.0.0-198.19.255.255
denied-peer-ip=198.51.100.0-198.51.100.255
denied-peer-ip=203.0.113.0-203.0.113.255
denied-peer-ip=240.0.0.0-255.255.255.255

log-file=/var/log/turnserver/turn.log
simple-log
