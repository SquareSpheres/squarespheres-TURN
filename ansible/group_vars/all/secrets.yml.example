# Copy this file to secrets.yml and fill in real values.
# secrets.yml is gitignored and never committed.

# TURN HMAC-SHA1 static auth secret.
turn_static_secret: "REPLACE_WITH_SECRET"

# Sudo password for the deploy user — hashed with SHA-512.
# Generate with (requires: pip3 install passlib):
#   python3 -c "from passlib.hash import sha512_crypt; print(sha512_crypt.hash('yourpassword'))"
deploy_sudo_password: "REPLACE_WITH_HASH"
